  "polling": {
    "interval_ms": 600000,
    "max_results_per_query": 50,
    "updated_since_hours": 48
  },
  "queries": [
    {
      "name": "recent_updates",
      "jql": "updated >= -48h ORDER BY updated DESC",
      "description": "All issues updated in the last 48 hours"
    },
    {
      "name": "high_priority_backlog",
      "jql": "priority in (Highest, High) AND status != Done ORDER BY priority DESC",
      "description": "High-priority items not yet completed"
    },
    {
      "name": "blockers_and_risks",
      "jql": "labels in (blocker, risk, escalate) OR issueType in (Bug, Incident) AND status not in (Done, Closed)",
      "description": "Issues tagged as blockers, risks, or incidents"
    }
  ],
  "filters": {
    "project_keys": ["SSP"],
    "labels_include": [
      "budget", "approval", "risk", "blocker", "milestone",
      "escalation", "dependency", "critical-path", "PMO"
    ],
    "labels_exclude": [
      "documentation-only", "cosmetic"
    ],
    "issue_types_include": [
      "Task", "Story", "Epic", "Bug", "Incident", "Sub-task"
    ],
    "statuses_trigger_gate": [
      "Blocked", "In Review", "Done"
    ]
  }
}
